transition:0.6s;
}

.card:hover{
transform:translateY(-25px) scale(1.05);
background:rgba(56,189,248,0.25);
}

/* FLEET */
.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(380px,1fr));
gap:45px;
margin-top:90px;
}

.gallery img{
