border-radius:40px;
transition:0.5s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* CONTACT */
input, textarea{
width:70%;
padding:22px;
margin:15px;
border-radius:35px;
border:none;
font-size:16px;
}

/* SOCIAL */
.social a{
display:inline-block;
margin:15px;
padding:18px 40px;
background:#020617;
color:white;
border-radius:35px;
text-decoration:none;
transition:0.4s;
}

.social a:hover{
background:#38bdf8;
}

/* FOOTER */
