/* HERO */
.hero{
height:100vh;
position:relative;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
overflow:hidden;
}

.hero video{
position:absolute;
width:100%;
height:100%;
object-fit:cover;
opacity:0.45;
transform:scale(1.1);
}

.hero img.logo-big{
height:150px;
margin-bottom:20px;
}

.hero h1{
font-size:130px;
margin:0;
letter-spacing:5px;
animation:fadeIn 2s;
}

.hero p{
font-size:28px;
max-width:1000px;
opacity:0.95;
}

/* BUTTON */
.btn{
padding:28px 85px;
border-radius:70px;
border:none;
background:linear-gradient(45deg,#0ea5e9,#38bdf8);
color:white;
font-size:24px;
cursor:pointer;
transition:0.4s;
margin-top:50px;
}

.btn:hover{
transform:scale(1.2);
}

/* SECTIONS */
.section{
padding:200px 170px;
text-align:center;
}

/* SERVICES */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(360px,1fr));
gap:90px;
margin-top:120px;
}

.card{
background:rgba(255,255,255,0.05);
padding:70px;
border-radius:55px;
border:1px solid rgba(255,255,255,0.1);
backdrop-filter: blur(40px);
transition:0.6s;
}

.card:hover{
transform:translateY(-40px) scale(1.08);
background:rgba(56,189,248,0.25);
}

/* FLEET */
.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(400px,1fr));
gap:55px;
margin-top:100px;
}

.gallery img{
width:100%;
border-radius:50px;
transition:0.5s;
}

.gallery img:hover{
transform:scale(1.1);
}

/* CONTACT */
input, textarea{
width:75%;
padding:28px;
margin:20px;
border-radius:40px;
border:none;
font-size:18px;
}

/* SOCIAL */
.social a{
display:inline-block;
margin:20px;
padding:22px 50px;
background:#020617;
color:white;
border-radius:45px;
text-decoration:none;
transition:0.4s;
}

.social a:hover{
background:#38bdf8;
}

/* FOOTER */
footer{
background:#000;
padding:130px;
text-align:center;
}

/* WHATSAPP FLOAT */
.whatsapp{
position:fixed;
bottom:40px;
right:40px;
background:#25D366;
padding:28px;
border-radius:50%;
font-size:34px;
text-decoration:none;
}

/* ANIMATION */
@keyframes fadeIn{
from{opacity:0; transform:translateY(140px);}
to{opacity:1; transform:translateY(0);}
}

</style>
